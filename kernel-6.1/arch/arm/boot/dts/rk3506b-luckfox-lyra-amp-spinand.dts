/dts-v1/;

#include "rk3506-luckfox-lyra-ultra.dtsi"
#include "rk3506-amp.dtsi"

/ {
	model = "Luckfox Lyra RK3506B AMP";
	compatible = "rockchip,rk3506g-demo-display-control", "rockchip,rk3506";

	chosen {
		bootargs = "earlycon=uart8250,mmio32,0xff0a0000 console=tty1 console=ttyFIQ0 root=ubi0:rootfs ubi.mtd=3 rootfstype=ubifs rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1";
	};

	dsm_sound: dsm-sound {
		status = "okay";
		compatible = "simple-audio-card";
		simple-audio-card,format = "i2s";
		simple-audio-card,mclk-fs = <256>;
		simple-audio-card,name = "rockchip-dsm-sound";
		simple-audio-card,bitclock-master = <&dsm_master>;
		simple-audio-card,frame-master = <&dsm_master>;
		simple-audio-card,cpu {
			sound-dai = <&sai3>;
		};
		dsm_master: simple-audio-card,codec {
			sound-dai = <&acdcdig_dsm>;
		};
	};

	vcc3v3_lcd: vcc3v3-lcd {
		status = "okay";
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <&lcd_pwren_h>;
		regulator-name = "vcc3v3_lcd";
		regulator-always-on;
	};
};

/**********media**********/
&mmc {
	/* For SDMMC */
	max-frequency = <52000000>;
	bus-width = <4>;
	no-sdio;
	no-mmc;
	cap-mmc-highspeed;
	cap-sd-highspeed;
	cd-gpios = <&gpio1 RK_PB6 GPIO_ACTIVE_LOW>; //det
	disable-wp;
	//sd-uhs-sdr104;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_clk_pins &sdmmc_cmd_pins &sdmmc_bus4_pins &sdmmc_det &sdmmc_pwren>;
	vqmmc-supply = <&vcc_3v3>;
	vmmc-supply = <&vcc_3v3>;
	status = "okay";
};

&fspi {
	status = "okay";

	flash@0 {
		compatible = "spi-nand";
		reg = <0>;
		spi-max-frequency = <80000000>;
		spi-rx-bus-width = <4>;
		spi-tx-bus-width = <1>;
	};
};

/**********display**********/
&cma {
	size = <0x2000000>;
};

&dsi {
	status = "okay";
};

&dsi_dphy {
	status = "okay";
};

&dsi_in_vop {
	status = "okay";
};

&route_dsi {
	status = "okay";
};

&dsi_panel {
	power-supply = <&vcc3v3_lcd>;
};

/**********ethernet**********/
&gmac1 {
	phy-mode = "rmii";
	clock_in_out = "output";

	snps,reset-gpio = <&gpio1 RK_PD0 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 20000 100000>;

	pinctrl-names = "default";
	pinctrl-0 = <&eth_rmii1_miim_pins &eth_rmii1_tx_bus2_pins &eth_rmii1_rx_bus2_pins &eth_rmii1_clk_pins>;

	phy-handle = <&rmii_phy1>;
	status = "okay";
};

&mdio1 {
	rmii_phy1: phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x1>;
	};
};

/**********usb**********/
&usb20_otg0 {
	dr_mode = "peripheral";
	status = "okay";
};

&usb20_otg1 {
	dr_mode = "host";
	status = "okay";
};

/**********Amp**********/
&reserved_memory {
	/* NuttX AMP secondary (CPU2) reserved region.
	 * Sized to cover the full NuttX footprint so Linux never treats any
	 * of it as free System RAM:
	 *   code  0x03e00000 - 0x03f00000  (1MB,  CONFIG_FLASH_*)
	 *   RAM   0x03f00000 - 0x05f00000  (32MB, CONFIG_RAM_SIZE=0x02000000)
	 * Total range: 0x03e00000 - 0x05f00000 = 0x02100000 (33MB).
	 * Load address 0x03e00000 unchanged, so ITS / U-Boot psci_cpu_on need
	 * no edit.
	 *
	 * ==== NuttX RAM upper limit (the NuttX source lives in an external
	 *      repo, so the constraint is documented here) ====
	 * The NuttX RK3506 port maps a fixed 256MB DDR window in its MMU setup
	 * (RK3506_DDR_SECSIZE = 256MB, VA/PA 0x00000000-0x10000000). NuttX RAM
	 * starts at CONFIG_RAM_START = 0x03f00000, so its end must stay within
	 * that window:
	 *   CONFIG_RAM_SIZE <= 0x10000000 - 0x03f00000 = 0x0C100000 (193MB).
	 * Going past 0x10000000 lands in an unmapped region -> data abort on
	 * first access. Whenever CONFIG_RAM_SIZE changes, this amp_reserved
	 * "reg" length MUST be updated to code(1MB) + CONFIG_RAM_SIZE, or Linux
	 * will reclaim the overflow as free RAM and corrupt NuttX.
	 */
	amp_reserved: amp@3e00000 {
		reg = <0x03e00000 0x2100000>;
		no-map;
	};
};

/**********pinctrl**********/
&pinctrl {
	lcd {
		lcd_pwren_h: lcd-pwren-h {
			rockchip,pins = <1 RK_PC4 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};
};
