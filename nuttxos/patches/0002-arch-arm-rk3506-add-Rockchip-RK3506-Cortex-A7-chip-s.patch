+ ****************************************************************************/
+
+/****************************************************************************
+ * Name: rk3506_setupmappings
+ *
+ * Description:
+ *   Initializes the non-code area page table
+ *
+ ****************************************************************************/
+
+int rk3506_setupmappings(void)
+{
+  mmu_l1_map_regions(g_section_mapping, nitems(g_section_mapping));
+
+  return 0;
+}
