+#
+# This file is autogenerated: PLEASE DO NOT EDIT IT.
+#
+# You can use "make menuconfig" to make any modifications to the installed .config file.
+# You can then do "make savedefconfig" to generate a new defconfig file that includes your
+# modifications.
+#
+CONFIG_16550_ADDRWIDTH=0
+CONFIG_16550_POLLING=y
+CONFIG_16550_REGINCR=1
+CONFIG_16550_REGWIDTH=32
+CONFIG_16550_UART=y
+CONFIG_16550_UART0=y
+CONFIG_16550_UART0_BAUD=1500000
+CONFIG_16550_UART0_BASE=0xff0e0000
+CONFIG_16550_UART0_CLOCK=24000000
+CONFIG_16550_UART0_IRQ=70
+CONFIG_16550_UART0_SERIAL_CONSOLE=y
+CONFIG_ALARM_ARCH=y
+CONFIG_ARCH="arm"
+CONFIG_ARCH_BOARD="luckfox-lyra-amp"
+CONFIG_ARCH_BOARD_LUCKFOX_LYRA_AMP=y
+CONFIG_ARCH_CHIP="rk3506"
+CONFIG_ARCH_CHIP_RK3506=y
+CONFIG_ARCH_INTERRUPTSTACK=2048
+CONFIG_ARCH_LOWVECTORS=y
+CONFIG_ARCH_STACKDUMP=y
+CONFIG_ARM_TOOLCHAIN_GNU_EABI=y
+CONFIG_BOARD_LATE_INITIALIZE=y
+CONFIG_BOARD_LOOPSPERMSEC=393693
+CONFIG_BUILTIN=y
+CONFIG_DEBUG_ASSERTIONS=y
+CONFIG_DEBUG_FEATURES=y
+CONFIG_DEBUG_FULLOPT=y
+CONFIG_DEBUG_SYMBOLS=y
+CONFIG_DEFAULT_TASK_STACKSIZE=4096
+CONFIG_DEV_ZERO=y
+CONFIG_EXAMPLES_HELLO=y
+CONFIG_FLASH_SIZE=1048576
+CONFIG_FLASH_START=0x03e00000
+CONFIG_FLASH_VSTART=0x03e00000
+CONFIG_FS_PROCFS=y
+CONFIG_FS_TMPFS=y
+CONFIG_IDLETHREAD_STACKSIZE=4096
+CONFIG_INIT_ENTRYPOINT="nsh_main"
+CONFIG_NSH_BUILTIN_APPS=y
+CONFIG_NSH_FILEIOSIZE=512
+CONFIG_NSH_READLINE=y
+CONFIG_RAM_SIZE=15728640
+CONFIG_RAM_START=0x03f00000
+CONFIG_RAM_VSTART=0x03f00000
+CONFIG_RAW_BINARY=y
+CONFIG_READLINE_CMD_HISTORY=y
+CONFIG_RR_INTERVAL=200
+CONFIG_SCHED_HAVE_PARENT=y
+CONFIG_SCHED_HPWORK=y
+CONFIG_SCHED_WAITPID=y
+CONFIG_SERIAL_UART_ARCH_MMIO=y
+CONFIG_START_DAY=23
+CONFIG_START_MONTH=6
+CONFIG_START_YEAR=2026
+CONFIG_SYSTEM_NSH=y
+CONFIG_UART0_SERIAL_CONSOLE=y
+CONFIG_USEC_PER_TICK=1000
+
+# === Sensor framework + uORB (local, no cross-core) =======================
+# Sensor 上半框架: 提供 /dev/uorb 设备节点、sensor_register()、上层 read/poll。
+CONFIG_SENSORS=y
+# USENSOR: 允许用户态通过 /dev/usensor 动态注册传感器 (uORB 依赖此项)。
+CONFIG_USENSOR=y
+# 假传感器: 从 CSV 文件读数据模拟物理传感器 (源文件 fakesensor_uorb.c),
+# 无需真实硬件即可产出 accel/gyro/baro/mag 数据流,用于演示完整 uORB 链路。
+CONFIG_SENSORS_FAKESENSOR=y
+# libm: uORB listener/test 用到 sqrt 等数学函数 (soft-float, 无 FPU)。
+CONFIG_LIBM=y
+
+# uORB 消息总线主开关 (apps/system/uorb), 依赖 SENSORS && USENSOR。
+CONFIG_UORB=y
+# uorb_listener 命令: 订阅并打印任意 topic 数据。
+CONFIG_UORB_LISTENER=y
+# uorb_generator 命令: 生成/发布测试数据。
+CONFIG_UORB_GENERATOR=y
+# uorb_unit_test 命令: 自建 topic 的发布/订阅/poll/拷贝单元测试 (无需硬件)。
+CONFIG_UORB_TESTS=y
+# 单元测试的计时结果落地目录 (默认 /data 不存在, 改到已挂载的 tmpfs /tmp)。
+CONFIG_UORB_STORAGE_DIR="/tmp"
+# Ctrl-C 中断信号: 让前台长运行命令(如 uorb_listener)可被 Ctrl-C 停止。
+# 轮询 RX 线程走 uart_recvchars() 经串口上半层, SIGINT 可正常生成。
+CONFIG_TTY_SIGINT=y
+CONFIG_SIG_DEFAULT=y
+# =========================================================================
+
+# === NSH 交互增强: Tab 补全 + 历史记录 ====================================
+# READLINE_ECHO 是 TABCOMPLETION 的前置(Kconfig 中 TABCOMPLETION 在 if ECHO 下)。
+CONFIG_READLINE_ECHO=y
+# Tab 补全: 补全 NSH builtin 命令名 (依赖 BUILTIN, 已开启)。
+CONFIG_READLINE_TABCOMPLETION=y
+# 命令历史(上/下方向键)已由上方 CONFIG_READLINE_CMD_HISTORY=y 提供。
+# =========================================================================
+
+# === RAM 文件系统工具 (在内存中创建并挂载文件系统) =======================
+# mkrd 包装器: 创建 RAM disk (BOARDIOC_MKRD), 让 NSH 'mkrd' 可用。
+# (ramdisk.c 常编, mkrd.c 由本项带出; NSH 侧自动 select BOARDCTL/BOARDCTL_MKRD)
+CONFIG_DRVR_MKRD=y
+# FAT 文件系统: 在 RAM disk 上格式化/挂载 FAT。
+CONFIG_FS_FAT=y
+CONFIG_FAT_LCNAMES=y
+CONFIG_FAT_LFN=y
+# mkfatfs 工具: NSH 'mkfatfs' 在块设备(含 RAM disk)上建 FAT。
+CONFIG_FSUTILS_MKFATFS=y
+# =========================================================================
+
+# === 内存测试工具 =========================================================
+# ramtest: 简单 RAM 读写/地址线/数据线/反码 测试 (NSH 'ramtest')。
+CONFIG_TESTING_RAMTEST=y
+# memtester: 经典 memtester 移植, 多种内存位模式测试 (NSH 'memtester')。
+CONFIG_UTILS_MEMTESTER=y
+# =========================================================================
+
+# === 文件系统测试工具 =====================================================
+# fstest: 通用文件系统读写/边界/随机 测试 (NSH 'fstest <mountpoint>')。
+CONFIG_TESTING_FSTEST=y
+# =========================================================================
